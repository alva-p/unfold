{
  "name": "unfold",
  "version": "0.1.0",
  "description": "Unfold any EVM contract in seconds",
  "bin": {
    "unfold": "./dist/index.cjs"
  },
  "main": "./dist/index.cjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/__tests__/standards.test.ts src/__tests__/storage-layout.test.ts src/__tests__/ast-analyzer.test.ts",
    "test:smoke": "vitest run src/__tests__/smoke.test.ts",
    "dev": "npx ts-node src/index.ts",
    "start": "node dist/index.cjs"
  },
  "keywords": [
    "ethereum",
    "evm",
    "solidity",
    "cli",
    "smart-contracts",
    "web3",
    "audit"
  ],
  "license": "MIT",
  "author": "alva-p",
  "dependencies": {
    "@solidity-parser/parser": "^0.20.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "inquirer": "^13.4.3",
    "ora": "^9.4.0",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
